<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
	  
	  <TargetFramework>net10.0-windows</TargetFramework>
	        <UseWindowsForms>true</UseWindowsForms>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <AssemblyName>MacPaletteExport</AssemblyName>
    <RootNamespace>MacPaletteExport</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <Platforms>AnyCPU</Platforms>
    <OutputType>Exe</OutputType>	
  </PropertyGroup>

  <ItemGroup>
    <!-- Krypton.Interop: direct reference required — it no longer flows transitively from
         Krypton.Toolkit (PrivateAssets="all", #3908) and must appear in this app's deps.json. -->
    <ProjectReference Include="..\..\Krypton Components\Krypton.Interop\Krypton.Interop.csproj" />
    <ProjectReference Include="..\..\Krypton Components\Krypton.Toolkit\Krypton.Toolkit 2022.csproj" />
  </ItemGroup>

</Project>
